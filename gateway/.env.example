# Copy to .env and fill in values

# ── Network config ─────────────────────────────────────────────────────────
# Absolute path to this repo's network/ directory
NETWORK_DIR=/home/user/dakar-cadastre/network

# Gateway peer (Municipality peer0 — the "primary" gateway peer)
PEER_ENDPOINT=localhost:7051
PEER_HOST_ALIAS=peer0.municipality.dakar.sn

# ── Chaincode ──────────────────────────────────────────────────────────────
CHANNEL_ID=dakar-cadastre
CHAINCODE_NAME=cadastre

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5176

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
# Token expiry
JWT_EXPIRES_IN=8h
